# Copy this file to .env and fill in the values.
# Never commit .env — it contains credentials.

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
#   DATABASE_URL=sqlite:///violence_detection.db
# PostgreSQL (recommended — requires Docker or a local PG install):
DATABASE_URL=postgresql://violence_user:violence_pass@localhost:5433/violence_db

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins, or * for any
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# ─── VideoMAE tuning (optional) ───────────────────────────────────────────────
VIDEOMAE_THRESHOLD=0.65
VIDEOMAE_SMOOTH_WINDOW=5
VIDEOMAE_MIN_PERSONS=2
